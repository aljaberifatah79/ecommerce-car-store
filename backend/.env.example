# Server Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/ecommerce-car-store
MONGODB_USER=
MONGODB_PASSWORD=

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# HyperPay Configuration (Payment Gateway)
HYPERPAY_API_KEY=your_hyperpay_api_key_here
HYPERPAY_MERCHANT_ID=your_merchant_id_here
HYPERPAY_API_URL=https://staging-api.hyperpay.net

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_password

# Frontend URL
FRONTEND_URL=http://localhost:3000

# AWS S3 (for image uploads)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=me-south-1
AWS_S3_BUCKET=ecommerce-car-store

# Pagination
ITEMS_PER_PAGE=20

# Logging
LOG_LEVEL=debug
